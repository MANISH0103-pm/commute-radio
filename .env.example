# ── Commute Radio · Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your real keys.
# The .env file is NEVER committed to git — it stays on your machine only.

# Anthropic Claude — for summarising posts and describing images
# Get yours at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# X (Twitter) login credentials
X_USERNAME=your_x_username
X_PASSWORD=your_x_password

# X accounts to scrape (comma-separated, no @ symbol)
X_ACCOUNTS=market_sleuth,Basssem666

# Text-to-speech voice (edge-tts — free, no API key needed)
# Options: en-US-AriaNeural (female), en-US-GuyNeural (male)
TTS_VOICE=en-US-AriaNeural

# Output folder — where generated .mp3 files land before deploy
AUDIO_OUTPUT_DIR=./output

# Vercel — your project's public URL (fill in after first deploy)
# Run: vercel --prod once, then copy the URL here
VERCEL_URL=https://commute-radio.vercel.app
